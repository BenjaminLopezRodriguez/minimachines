#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../node_modules/pnpm/bin/pnpm.cjs" "$@"
else
  exec node  "$basedir/../node_modules/pnpm/bin/pnpm.cjs" "$@"
fi
# cmd-shim-target=/Users/benji/projects/minimachines/.pnpm-store/v11/links/@/pnpm/10.27.0/1a120c049688e12cd6aba74b0e72d92e185dfcdad4f9d1ba4149728e22fce575/node_modules/pnpm/bin/pnpm.cjs
