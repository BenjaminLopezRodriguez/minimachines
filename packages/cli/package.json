{
  "name": "@minimachines/cli",
  "version": "0.1.2",
  "description": "CLI to attach to minimachin.es machine sessions",
  "type": "module",
  "bin": {
    "cli": "./dist/cli.js"
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"require('fs').chmodSync('dist/cli.js',0o755)\"",
    "dev": "tsx src/cli.ts",
    "prepublishOnly": "pnpm build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "open": "^10.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": ["minimachines", "minimachine", "cli", "agents", "vm"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BenjaminLopezRodriguez/minimachines.git",
    "directory": "packages/cli"
  }
}
