{
  "name": "minimachine",
  "version": "0.1.0",
  "description": "SDK and MCP server for spinning up sessions on minimachin.es",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "minimachine-mcp": "./dist/mcp.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/mcp.ts",
    "test": "tsx --test src/client.test.ts",
    "prepublishOnly": "pnpm build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  },
  "keywords": [
    "minimachine",
    "minimachines",
    "mcp",
    "agents",
    "vm"
  ],
  "license": "MIT"
}
